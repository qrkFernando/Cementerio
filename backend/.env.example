# Opción recomendada (una sola variable)
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# Opción alternativa (variables separadas)
PGHOST=localhost
PGPORT=5433
PGUSER=postgres
PGPASSWORD=root
PGDATABASE=bd

# App
NODE_ENV=development
APP_NAME=Cementerio
APP_ORIGIN=http://localhost:5173
PORT=3001

# Google Maps (Admin UI: Places Autocomplete + mapa interactivo)
# Recomendación: restringir por HTTP referrer (ej: http://localhost:5173/*)
GOOGLE_MAPS_API_KEY=

# Cookies / sesión
SESSION_SECRET=cementerio_backend_super_seguro_2026_token_xd

# Bootstrap (opcional): el primer admin del sistema
# Si defines BOOTSTRAP_ADMIN_EMAIL, el backend asegura que exista como rol admin
# y marca el correo como verificado (email_verified_at).
#
# Recomendado: define también la contraseña inicial.
# Si NO defines BOOTSTRAP_ADMIN_PASSWORD, se generará una contraseña fuerte y se
# imprimirá en consola al crear/actualizar el admin.
#
BOOTSTRAP_ADMIN_EMAIL=adminCementerio@Cementerio.com
BOOTSTRAP_ADMIN_PASSWORD=Admin@123

# OTP
# Recomendado: define un secreto dedicado para OTP (en prod, distinto a SESSION_SECRET)
OTP_SECRET=
OTP_EXPIRES_MIN=10
OTP_EMAIL_SUBJECT=Tu código de verificación

# SMTP (para envío real de correos)
# Si no lo configuras, en dev el código se imprimirá en consola.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Sistema Cementerio <>
SMTP_SECURE=false

# SSL (útil en entornos cloud)
# PGSSL=true
# PGSSL_REJECT_UNAUTHORIZED=true
